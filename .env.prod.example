# Neoman-Go production environment example.
# Placeholder values only. Do not commit real production secrets.
# Create a local .env.prod on the production server from this template.

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

DB_URL=jdbc:mysql://your-rds-endpoint:3306/neomango?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=your-db-username
DB_PASSWORD=change-me

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me

JWT_SECRET=change-me-at-least-32-bytes
JWT_ACCESS_TOKEN_VALIDITY_SECONDS=1800
JWT_REFRESH_TOKEN_VALIDITY_SECONDS=1209600

CORS_ALLOWED_ORIGINS=https://neomango.kr

ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_EMAIL=
# Set ADMIN_PASSWORD only during the first controlled ADMIN bootstrap run.
# Remove ADMIN_PASSWORD from .env.prod immediately after the ADMIN account is created.
ADMIN_PASSWORD=
ADMIN_NICKNAME=
