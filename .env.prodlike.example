SPRING_PROFILES_ACTIVE=prodlike

DB_NAME=neomango_prodlike
DB_USERNAME=<prodlike-db-username>
DB_PASSWORD=<prodlike-db-password>
DB_ROOT_PASSWORD=<prodlike-db-root-password>
DB_URL=jdbc:mysql://mysql:3306/neomango_prodlike?serverTimezone=Asia/Seoul&characterEncoding=UTF-8

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<prodlike-redis-password>

JWT_SECRET=<prodlike-jwt-secret-at-least-32-bytes>
JWT_ACCESS_TOKEN_VALIDITY_SECONDS=1800
JWT_REFRESH_TOKEN_VALIDITY_SECONDS=1209600

CORS_ALLOWED_ORIGINS=http://localhost:5173

ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_EMAIL=<prodlike-admin-email>
ADMIN_PASSWORD=<prodlike-admin-initial-password>
ADMIN_NICKNAME=<prodlike-admin-nickname>
